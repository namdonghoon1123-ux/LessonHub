# ── 로컬 개발 / 테스트 (Supabase dev DB 연결) ──
# Supabase 프로젝트(가급적 운영과 분리된 dev 프로젝트)의 connection string.
#   Supabase 대시보드 → Settings → Database → Connection string (URI)
#   Serverless 환경에선 pooler(transaction, 6543) 권장.
# ⚠️ 통합테스트(npm test)는 예약/시간표 테이블을 TRUNCATE 하므로
#    반드시 "버려도 되는" dev DB 를 사용할 것. 운영 DB 금지.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# JWT 서명 키 (운영은 무작위 32바이트 이상으로 교체)
JWT_SECRET=change-this-in-real-env

# 백엔드를 로컬에서 직접 띄울 때 포트 (node backend/src/index.js)
PORT=4000

# 로컬은 비워두면 development. 운영(Vercel)은 production 으로 설정.
# NODE_ENV=development

# ── (선택) 소셜 로그인 OAuth Client ID ──
# 설정하면 /api/v1/auth/social/providers 응답에서 enabled:true 가 됨.
# 실제 OAuth 흐름(authorization code → token)은 별도 구현 필요.
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_NAVER_CLIENT_ID=
# OAUTH_KAKAO_CLIENT_ID=

# ── (선택) Supabase Auth 도입 시 ──
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOi...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # backend 전용. 절대 frontend 노출 금지
