# ── Docker 로컬 개발 ──
POSTGRES_DB=lesson_booking
POSTGRES_USER=lesson_user
POSTGRES_PASSWORD=lesson_pass
POSTGRES_PORT=5432

BACKEND_PORT=4000
FRONTEND_PORT=18080

# 로컬 Docker 기준 connection string
DATABASE_URL=postgresql://lesson_user:lesson_pass@db:5432/lesson_booking

# JWT 서명 키 (배포 시 무작위 32바이트 이상으로 교체)
JWT_SECRET=change-this-in-real-env

# ── Vercel + Supabase 배포 ──
# 위 DATABASE_URL 을 아래 형태로 교체하면 그대로 동작한다.
# 1) Supabase 대시보드 → Settings → Database → Connection string (URI, "session" 모드 또는 "transaction" 모드)
#    Vercel Serverless 환경에서는 connection pooler ("transaction" 모드, 6543 포트) 권장.
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
# 2) Supabase Auth 를 도입할 경우 (자체 JWT 유지하면 불필요)
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOi...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # backend 전용. 절대 frontend 노출 금지
